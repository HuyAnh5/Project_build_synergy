    icon: {fileID: 0}
    descriptionMode: 0
    description: Lowest possible dice value.
  - keyword: Freeze
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Skip the next action.
  - keyword: Chill
    displayName: Chilled
    icon: {fileID: 0}
    descriptionMode: 0
    description: Weakens the enemy; used to trigger Ice effects.
  - keyword: Mark
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Lightning mark; some skills become stronger when hitting a target
      with Mark.
  - keyword: Stagger
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: State that causes the target to take more damage.
  - keyword: Add Value
