--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f1a8b2c3d4e5f67890123456789abcd, type: 3}
  m_Name: SkillTooltipKeywordGlossary
  m_EditorClassIdentifier: Assembly-CSharp::SkillTooltipKeywordGlossarySO
  entries:
  - keyword: Burn
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Stack on the enemy; does not deal damage on its own and can be Consumed by skills.
  - keyword: Consume
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Remove stack/status to trigger an effect.
  - keyword: Crit
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Highest possible dice value.
  - keyword: Fail
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Lowest possible dice value.
  - keyword: Freeze
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Skip the next action.
  - keyword: Chill
    displayName: Chilled
    icon: {fileID: 0}
    descriptionMode: 0
    description: Weakens the enemy; used to trigger Ice effects.
  - keyword: Mark
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Lightning mark; some skills become stronger when hitting a target with Mark.
  - keyword: Stagger
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: State that causes the target to take more damage.
  - keyword: Add Value
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 0
    description: Bonus that increases the main skill value; green numbers receive this bonus.
  - keyword: '...'
    displayName: 
    icon: {fileID: 0}
    descriptionMode: 1
    description: Current value is {value} after Add Value and modifiers are applied.
